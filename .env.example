# ─────────────────────────────────────────────────────────────
# REQUIRED
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection string.
# Local (Docker): postgres://postgres:payload@localhost:5432/payload
# Coolify:        postgres://<user>:<pass>@<host>:5432/<db>
DATABASE_URI=postgres://postgres:payload@localhost:5432/payload

# Payload secret key — minimum 32 characters. Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=

# Full public URL of this Next.js app (no trailing slash).
# Local:   http://localhost:3000
# Coolify: https://your-domain.com
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# ANALYTICS & SEARCH CONSOLE (optional)
# Injected only when the field is set; blank = nothing injected.
# Configure in the CMS under Site → Integrations for live control.
# ─────────────────────────────────────────────────────────────
# GA4 Measurement ID — e.g. G-XXXXXXXXXX
# GA4_MEASUREMENT_ID=

# Google Search Console HTML-tag verification code
# GOOGLE_SITE_VERIFICATION=

# ─────────────────────────────────────────────────────────────
# COOLIFY / PRODUCTION EXTRAS
# ─────────────────────────────────────────────────────────────
# NODE_ENV=production
#
# Media uploads persist via a mounted volume at /app/media
# (set in Coolify service → Volumes → /app/media → persistent).
#
# If you later scale to multiple instances, add:
# REDIS_URL=redis://<host>:6379
# and configure a Redis ISR cache handler in next.config.ts.
